{
  "name": "@acrolinx/sidebar-sdk",
  "private": false,
  "version": "2.1.0",
  "type": "module",
  "author": "Acrolinx",
  "url": "https://www.acrolinx.com",
  "repository": "https://github.com/acrolinx/sidebar-sdk-js",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build-doc": "typedoc --out ./docs/pluginDoc/ src/",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "test": "vitest",
    "coverage": "vitest run --coverage --browser.headless"
  },
  "devDependencies": {
    "@ckeditor/ckeditor5-build-inline": "40.2.0",
    "@ckeditor/ckeditor5-source-editing": "40.2.0",
    "@codemirror/view": "^6.41.1",
    "@eslint/js": "^10.0.1",
    "@types/ckeditor": "^4.9.10",
    "@types/ckeditor4": "^4.20.7",
    "@types/codemirror": "^5.60.16",
    "@types/diff-match-patch": "^1.0.36",
    "@types/quill": "^2.0.14",
    "@types/tinymce": "^5.5.0",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-istanbul": "^4.1.2",
    "ckeditor4": "4.22.1",
    "codemirror": "5.65.19",
    "eslint": "^10.3.0",
    "fast-check": "^4.7.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prosemirror-model": "^1.23.0",
    "prosemirror-schema-basic": "^1.2.2",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.41.8",
    "quill": "1.3.7",
    "tinymce": "^8.5.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.4"
  },
  "dependencies": {
    "@acrolinx/sidebar-interface": "^15.4.3",
    "@acrolinx/sidebar-startpage": "^4.0.5",
    "diff-match-patch": "^1.0.5",
    "entities": "^8.0.0"
  }
}
